      }
    ]
  },
  {
    "anchor": null,
    "type": "stanza",
    "paragraph": null,
    "sentences": [
      {
        "verse": 2,
        "content": "El pasado ya pasó y el futuro aún no ha tenido lugar."
      },
      {
        "verse": 3,
        "content": "Ahora me he liberado de ambos."
      },
      {
        "verse": 4,
        "content": "Pues lo que Dios da solo puede ser para el bien."
      },
      {
        "verse": 5,
        "content": "Y acepto únicamente lo que Él da como lo que me pertenece."
      }
